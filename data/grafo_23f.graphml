      <data key="d7">False</data>
      <data key="d8">1705</data>
      <data key="d9">C) LA DIRECCION ESTIMO QUE MIENERAS EL SUMARIO ESTUVIERA ABIERTO, A LA VISTA DE LAS IMPUTACIONES DE CONOCIMIENTO PREVIO QUE SE LE NACIAN AL COMANDANTE CORTINA Y DADO SU ESPECIAL COMETIDO Y RESPONSABILIDADES EN EL CENTRO, ERA CONVENIENTE PARA EL MISMO SU CONSIGUIENTE BAJA EN LA UNIDAD Y SU DESE EN EL CESID.</data>
    </edge>
