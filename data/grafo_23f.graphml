    <edge source="Coronel" target="Mando" id="17">
      <data key="d5">MENCIONA</data>
      <data key="d6">MENCIONA</data>
      <data key="d7">False</data>
      <data key="d8">1701</data>
      <data key="d9">EL GENERAL PRIETO INSISTIDO EN QUE EL TENIENTE CORONEL TEJERO HÁ ORDENES DE UN SUPERIOR, CUYO NOMBRE Y GRADUACIÓN NO SE DIFICARON, Y, PREGUNTADO SI EXISTÍA ALGUN MILITAR DE LA MÁXIMA NACIÓN COMO ORGANIZADOR DE LA OPERACIÓN, EL GENERAL EN LA RESERVA ESTÁ QUE NO EL CREE QUE NINGÚN ALTO MANDO DEL EJERCITO ESTÉ CADO EN LA MISMA.</data>
    </edge>
    <edge source="Coronel" target="Mando" id="18">
      <data key="d5">MENCIONA</data>
      <data key="d6">MENCIONA</data>
      <data key="d7">False</data>
      <data key="d8">1701</data>
      <data key="d9">LA EXIGENCIA DE QUE EL CITADO TENIENTE CORONEL Y LAS FUERZAS A SU MANDO DEPONGAN INMEDIATA E INCONDICIONALMENTE SU ACTITUD, ENTREGANDOSE A LAS AUTORIDADES MILITARES, QUE, BAJO LA DIRECCIÓN DEL GOBIERNO EN FUNCIONES Y DE LA JUNTA DE JEFES DE ESTADO MAYOR, CUSTODIAN EL CONGRESO DE LOS DIPUTADOS, SIGUIENDO EL MANDATO INEQUIVO CO DE S.M.</data>
    </edge>
    <edge source="Coronel" target="General Juste" id="0">
