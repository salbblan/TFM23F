      <data key="d7">False</data>
      <data key="d8">1701</data>
      <data key="d9">OP: NORMALIDAD ABSOLUTA EN CANARIAS  SANTA CRUZ DE TENERIFE, 23 (EFE), - NORMALIDAD ABSOLUTA ERA LA NOTA PREDOMINANTE ESTA TARDE EN CANARIAS TRAS CONOCERSE LA NOTICIA DE LOS INCIDENTES OCURRIDOS EN EL CONGRESO DE LOS DIPUTADOS.</data>
    </edge>
    <edge source="Diputados" target="El Congreso" id="10">
      <data key="d5">ORDENA</data>
      <data key="d6">RECIBE_ORDEN</data>
      <data key="d7">False</data>
      <data key="d8">1701</data>
      <data key="d9">DOS DE LAS PERSONAS QUE IMPARTIAN ORDENES A LOS MIEMBROS DE LA GUARDIA CIVIL QUE HAN OCUPADO EL CONGRESO DE LOS DIPUTADOS, NO VESTIAN MINGUN UNIFORME.</data>
    </edge>
    <edge source="Diputados" target="El Congreso" id="11">
      <data key="d5">MENCIONA</data>
      <data key="d6">MENCIONA</data>
      <data key="d7">False</data>
      <data key="d8">1701</data>
      <data key="d9">LA EXIGENCIA DE QUE EL CITADO TENIENTE CORONEL Y LAS FUERZAS A SU MANDO DEPONGAN INMEDIATA E INCONDICIONALMENTE SU ACTITUD, ENTREGANDOSE A LAS AUTORIDADES MILITARES, QUE, BAJO LA DIRECCIÓN DEL GOBIERNO EN FUNCIONES Y DE LA JUNTA DE JEFES DE ESTADO MAYOR, CUSTODIAN EL CONGRESO DE LOS DIPUTADOS, SIGUIENDO EL MANDATO INEQUIVO CO DE S.M.</data>
    </edge>
    <edge source="Diputados" target="El Congreso" id="12">
