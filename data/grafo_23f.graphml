    <edge source="La Guardia Civil" target="Palacio Del Congreso" id="0">
      <data key="d5">ORDENA</data>
      <data key="d6">RECIBE_ORDEN</data>
      <data key="d7">False</data>
      <data key="d8">1701</data>
      <data key="d9">EL MINISTERIO DE INTERIOR HA CURSADO ORDENES A LOS GOBIERNOS CIVILES DE MANTENER EL "ESTADO DE ALERTA" Y LAS CERCANIAS DEL PALACIO DEL CONGRESO ESTAN ACORDONADAS POR LA GUARDIA CIVIL, CUYOS MEMBROS NO PERMITEN EL ACCESO NI A LOS MIEMBROS DE LA POLICIA.</data>
    </edge>
    <edge source="La Guardia Civil" target="Parque" id="0">
      <data key="d5">PERTENECE</data>
      <data key="d6">PERTENECE_A</data>
      <data key="d7">True</data>
      <data key="d8">1701</data>
      <data key="d9">DOS DE ESTOS AUTOBUSES NO PERTENECEN AL PARQUE MOVIL DE LA GUARDIA CIVIL, SINO QUE SON DE UNA EMPRESA PRIVADA, CONCRETAMENTE DE LA EMPRESA "AUTOBUSES HERRANZ", DE SAN LORENZO DE EL ESCORIAL, E IBAN CONDUCIDOS POR PERSONAS DE PAISANO.</data>
    </edge>
    <edge source="La Guardia Civil" target="Parque" id="1">
      <data key="d5">PERTENECE</data>
      <data key="d6">PERTENECE_A</data>
      <data key="d7">False</data>
      <data key="d8">1701</data>
      <data key="d9">LAS MUERZAS CON LAS QUE CUENTA DENTRO DEL CONGRESO PERTENECEN AL PARQUE LOVIL DE LA GUARDIA CIVIL Y PUEDEN SER DE 200 A 300 SUS COMPONENTES.</data>
    </edge>
    <edge source="La Guardia Civil" target="Periodistas" id="0">
      <data key="d5">ORDENA</data>
      <data key="d6">RECIBE_ORDEN</data>
      <data key="d7">False</data>
      <data key="d8">1701</data>
      <data key="d9">SOBRE LAS NUEVE Y DIEZ MINUTOS DE LA NOCHE, Y DESPUES DE QUE SE LEYERA ANTE LOS DIPUTADOS EL COMUNICADO DEL TENIENTE GENERAL MILANS DEL BOSCH, EL TENIENTE CORONEL DE LA GUARDIA CIVIL QUE ENCABEZABA A LAS FUERZAS OCUPANTES, ORDENO A LOS DIPUTADOS, PERIODISTAS E INVITADOS QUE MANTUVIERAN SILENCIO Y NO SE MOVIERAN DE SUNO A LAS FUERZA CASO DE QUE SE APAGARA LA LUZ Y AL PARECER, ORDENO A LAS FUERZAS QUE HICIERAN FUEGO SI SE DESOBEDECIA SU ORDEN.</data>
    </edge>
    <edge source="La Guardia Civil" target="Teniente General Milans Del Bosch" id="0">
      <data key="d5">ORDENA</data>
      <data key="d6">RECIBE_ORDEN</data>
