    <edge source="Cir Nº 2" target="Coronel" id="0">
      <data key="d5">CONOCE</data>
      <data key="d6">CONOCE</data>
      <data key="d7">False</data>
      <data key="d8">1723</data>
      <data key="d9">Preguntado si conocía al coronel Maisterra, del CIR nº 2, manifiesta conocerle de sus tiempos de cadete, no habiendolo vuelto a ver desde entonces.</data>
    </edge>
