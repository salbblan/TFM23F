    <edge source="Coronel" target="Teniente General Milans Del Bosch" id="1">
      <data key="d5">PERTENECE</data>
      <data key="d6">PERTENECE_A</data>
      <data key="d7">False</data>
      <data key="d8">1701</data>
      <data key="d9">ALGUN MIEMBRO DE LA JUNTA HA TOMADO CONTACTO A TRAVÉS DE TERCEROS CON PERSONAS QUE PERMANECEN DENTRO DEL RECINTO DEL CONGRESO Y HA PODIDO SABER QUE EL TENIENTE CORONEL, ANTONIO TEJERO MOLINA, HA MANIFESTADO, AL PARECER, QUE NO OBEDECERA MÁS ORDENES QUE LAS DEL REY Y DEL TENIENTE GENERAL MILANS DEL BOSCH.</data>
    </edge>
    <edge source="Coronel" target="Ejercito" id="0">
      <data key="d5">MENCIONA</data>
      <data key="d6">MENCIONA</data>
      <data key="d7">False</data>
      <data key="d8">1701</data>
      <data key="d9">EL TENIENTE CORONEL TEJERO MOLINA FUE UNO DE LOS ASISTENTES A LA VIGIÓN DE LA CAFETERÍA +GALAXIA+ DE MADRID, A LA QUE ASISTIERON LOS OFICIALES DEL EJERCITO, Y EN LA QUE SE PLANTEÓ LA POSIBILIDAD LLEVAR A CADO +UN GOLPE DE MANO+ CONTRA EL PALACIO DE LA MONCLOA, E DE LA PRESIDENCIA DEL GOBIERNO.</data>
    </edge>
    <edge source="Coronel" target="Ejercito" id="1">
      <data key="d5">MENCIONA</data>
      <data key="d6">MENCIONA</data>
      <data key="d7">False</data>
      <data key="d8">1701</data>
      <data key="d9">INCIDENTE EN EL CONGRESO  SEGÚN EL GENERAL PRIETO, EL TENIENTE CORONEL TEJERO PODRÍA ACATAR ORDEN DEL REY  ADRID, 23 (EFE).-  EL GENERAL PRIETO, QUE SE HA ENTREVISTADO ESTA NOCHE EN EL RECINTO PÁLACIO DEL CONGRESO CON EL TENIENTE CORONEL TEJERO, HA EXPRESADO (EFE), A LA SALIDA, QUE TEJERO PODRÍA ACATAR UNA ORDEN DEL REY COMO HA AUTORIDAD DEL EJERCITO, AUNQUE, ACLARO, "ESTO ES SOLO UNA DICIÓN".</data>
    </edge>
    <edge source="Coronel" target="Ejercito" id="2">
      <data key="d5">MENCIONA</data>
      <data key="d6">MENCIONA</data>
      <data key="d7">False</data>
      <data key="d8">1701</data>
      <data key="d9">EL GENERAL PRIETO INSISTIDO EN QUE EL TENIENTE CORONEL TEJERO HÁ ORDENES DE UN SUPERIOR, CUYO NOMBRE Y GRADUACIÓN NO SE DIFICARON, Y, PREGUNTADO SI EXISTÍA ALGUN MILITAR DE LA MÁXIMA NACIÓN COMO ORGANIZADOR DE LA OPERACIÓN, EL GENERAL EN LA RESERVA ESTÁ QUE NO EL CREE QUE NINGÚN ALTO MANDO DEL EJERCITO ESTÉ CADO EN LA MISMA.</data>
    </edge>
    <edge source="Coronel" target="Presidencia Del Gobierno" id="0">
