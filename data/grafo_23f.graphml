      <data key="d5">CONOCE</data>
      <data key="d6">CONOCE</data>
      <data key="d7">True</data>
      <data key="d8">1830</data>
      <data key="d9">Que al Guardia Civil José Gutierrez de la Rosa, citado por el letrado, no le conoce, ni supo si estaba en la zona; quizás le acompañara al Gral.</data>
    </edge>
    <edge source="Guardia Civil" target="Zona" id="1">
      <data key="d5">MENCIONA</data>
