    <edge source="Servicio" target="Unidad" id="1">
      <data key="d5">PERTENECE</data>
      <data key="d6">PERTENECE_A</data>
      <data key="d7">True</data>
      <data key="d8">1839</data>
      <data key="d9">Se hace referencia al Grupo de Operaciones del Servicio de Información (GOSI) de la Guardia Civil hablando del Cabo Monge, y no haberle tenido en ninguna unidad a su mando; y que el Grupo no pertenecía al CESID.</data>
    </edge>
    <edge source="Servicio" target="Unidad" id="2">
      <data key="d5">ORDENA</data>
