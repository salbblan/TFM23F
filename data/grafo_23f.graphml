      <data key="d7">False</data>
      <data key="d8">1810</data>
      <data key="d9">LAINA, el defensor de Capitán MÚRECAS, el Teniente CARRICONDO pide que se describe que es de nacional figura en el escrito de declaración y a que hora se realice el mensaje de S.M.</data>
    </edge>
    <edge source="Capitán" target="Defensor" id="5">
