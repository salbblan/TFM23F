      <data key="d8">1701</data>
      <data key="d9">LA NOTA OFICIAL DEL MENCIONADO MINISTERIO ES LA SIGUIENTE:  +LA SITUACION CREADA POR EL ACJO DE VIOLENCIA EN LA SEDE DEL CONGRESO DE LOS DIPUTADOS HA EVITADO HASTA EL MOMENTO LA ACCION NORMAL DEL CONSEJO DE MINISTROS, CUYOS MIEMBROS SE ENCUENTRAN RETENIDOS EN LA CAMARA.</data>
    </edge>
