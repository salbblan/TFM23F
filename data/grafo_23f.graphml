      <data key="d6">RECIBE_ORDEN</data>
      <data key="d7">False</data>
      <data key="d8">1701</data>
      <data key="d9">LOS EFECTIVOS DE LA GUARDIA CIVIL ORDENARON A LOS INFORMADORES "QUE N OS ENCONTRABANOS EN LA SALA DE PRENSA Y OTRAS DEPENDENCIAS DEL CONGRESO COLGAR LOS TELEFONOS, NO ASOMARNOS A LAS VENTANAS Y PERMANECER EN EL LOCAL".</data>
    </edge>
