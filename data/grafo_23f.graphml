      <data key="d5">CONOCE</data>
      <data key="d6">CONOCE</data>
      <data key="d7">True</data>
      <data key="d8">1839</data>
      <data key="d9">No conocía al Teniente Coronel Tejero directamente, ni sus proyectos para el 23 F; tampoco conocía el viaje a Valencia del Comandante Pardo ni la ausencia del General Juste y Coronel San Martín por viaje a Zaragoza.</data>
    </edge>
    <edge source="Valencia" target="Zaragoza" id="1">
      <data key="d5">LLAMA</data>
      <data key="d6">LLAMA_A</data>
