    <edge source="Diputados" target="Vitoria" id="0">
      <data key="d5">CONOCE</data>
      <data key="d6">CONOCE</data>
      <data key="d7">False</data>
      <data key="d8">1701</data>
      <data key="d9">EL GOBERNADOR GENERAL PARA EL PAIS VASCO, MERCELINO OREJA AGUIRRE, HA REINCORPORADO ESTA NOCHE A SU DESPACHO EN VITORIA, TRAS CONOCER INCIDENTE QUE HA PROTAGONIZADO UN GRUPO DE GUARDIAS CIVILES EN EL NORESO DE LOS DIPUTADOS.</data>
    </edge>
    <edge source="Diputados" target="Periodistas" id="0">
      <data key="d5">ORDENA</data>
      <data key="d6">RECIBE_ORDEN</data>
      <data key="d7">False</data>
      <data key="d8">1701</data>
      <data key="d9">SOBRE LAS NUEVE Y DIEZ MINUTOS DE LA NOCHE, Y DESPUES DE QUE SE LEYERA ANTE LOS DIPUTADOS EL COMUNICADO DEL TENIENTE GENERAL MILANS DEL BOSCH, EL TENIENTE CORONEL DE LA GUARDIA CIVIL QUE ENCABEZABA A LAS FUERZAS OCUPANTES, ORDENO A LOS DIPUTADOS, PERIODISTAS E INVITADOS QUE MANTUVIERAN SILENCIO Y NO SE MOVIERAN DE SUNO A LAS FUERZA CASO DE QUE SE APAGARA LA LUZ Y AL PARECER, ORDENO A LAS FUERZAS QUE HICIERAN FUEGO SI SE DESOBEDECIA SU ORDEN.</data>
    </edge>
    <edge source="Diputados" target="Teniente General Milans Del Bosch" id="0">
      <data key="d5">ORDENA</data>
      <data key="d6">RECIBE_ORDEN</data>
      <data key="d7">False</data>
      <data key="d8">1701</data>
      <data key="d9">SOBRE LAS NUEVE Y DIEZ MINUTOS DE LA NOCHE, Y DESPUES DE QUE SE LEYERA ANTE LOS DIPUTADOS EL COMUNICADO DEL TENIENTE GENERAL MILANS DEL BOSCH, EL TENIENTE CORONEL DE LA GUARDIA CIVIL QUE ENCABEZABA A LAS FUERZAS OCUPANTES, ORDENO A LOS DIPUTADOS, PERIODISTAS E INVITADOS QUE MANTUVIERAN SILENCIO Y NO SE MOVIERAN DE SUNO A LAS FUERZA CASO DE QUE SE APAGARA LA LUZ Y AL PARECER, ORDENO A LAS FUERZAS QUE HICIERAN FUEGO SI SE DESOBEDECIA SU ORDEN.</data>
    </edge>
    <edge source="Diputados" target="Estado Mayor" id="0">
      <data key="d5">MENCIONA</data>
      <data key="d6">MENCIONA</data>
      <data key="d7">False</data>
      <data key="d8">1701</data>
      <data key="d9">LA EXIGENCIA DE QUE EL CITADO TENIENTE CORONEL Y LAS FUERZAS A SU MANDO DEPONGAN INMEDIATA E INCONDICIONALMENTE SU ACTITUD, ENTREGANDOSE A LAS AUTORIDADES MILITARES, QUE, BAJO LA DIRECCIÓN DEL GOBIERNO EN FUNCIONES Y DE LA JUNTA DE JEFES DE ESTADO MAYOR, CUSTODIAN EL CONGRESO DE LOS DIPUTADOS, SIGUIENDO EL MANDATO INEQUIVO CO DE S.M.</data>
    </edge>
    <edge source="Diputados" target="Mando" id="0">
      <data key="d5">MENCIONA</data>
      <data key="d6">MENCIONA</data>
      <data key="d7">False</data>
      <data key="d8">1701</data>
      <data key="d9">LA EXIGENCIA DE QUE EL CITADO TENIENTE CORONEL Y LAS FUERZAS A SU MANDO DEPONGAN INMEDIATA E INCONDICIONALMENTE SU ACTITUD, ENTREGANDOSE A LAS AUTORIDADES MILITARES, QUE, BAJO LA DIRECCIÓN DEL GOBIERNO EN FUNCIONES Y DE LA JUNTA DE JEFES DE ESTADO MAYOR, CUSTODIAN EL CONGRESO DE LOS DIPUTADOS, SIGUIENDO EL MANDATO INEQUIVO CO DE S.M.</data>
