      <data key="d6">RECIBE_ORDEN</data>
      <data key="d7">True</data>
      <data key="d8">1841</data>
      <data key="d9">El resto de los defensores que hacen uso de su turno inciden en que los procesados no recibieron orden alguna durante el 23F para que depusieran su actitud.</data>
    </edge>
