      <data key="d8">1797</data>
      <data key="d9">01-04-81  F (1220-1315 en despacho JDDI)  Dice no tener ningún conocimiento previo del proyecto del asalto.</data>
    </edge>
    <edge source="Capitán Garcia Almenta" target="Congreso" id="0">
