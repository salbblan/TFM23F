    <edge source="El Congreso" target="Estado Mayor" id="0">
      <data key="d5">MENCIONA</data>
      <data key="d6">MENCIONA</data>
      <data key="d7">False</data>
      <data key="d8">1701</data>
      <data key="d9">LA EXIGENCIA DE QUE EL CITADO TENIENTE CORONEL Y LAS FUERZAS A SU MANDO DEPONGAN INMEDIATA E INCONDICIONALMENTE SU ACTITUD, ENTREGANDOSE A LAS AUTORIDADES MILITARES, QUE, BAJO LA DIRECCIÓN DEL GOBIERNO EN FUNCIONES Y DE LA JUNTA DE JEFES DE ESTADO MAYOR, CUSTODIAN EL CONGRESO DE LOS DIPUTADOS, SIGUIENDO EL MANDATO INEQUIVO CO DE S.M.</data>
    </edge>
    <edge source="El Congreso" target="El Gobierno" id="0">
      <data key="d5">SOLICITA</data>
      <data key="d6">SOLICITA</data>
      <data key="d7">False</data>
      <data key="d8">1701</data>
      <data key="d9">JUAN PLA INFORMO AL TENIENTE CORONEL TEJERO DE LA SITUACION EN TODO EL PAIS, QUE EL CONOCIA A TRAVES DE LA RADIO, Y LE PIDIO QUE LE RECIBIERA EN EL CONGRESO, PORQUE EN EL MINISTERIO DEL INTERIOR LE HABIAN GARANTIZADO LA SOLUCION PARA EL Y SU FAMILIA, ASI COMO PARA LOS HOMBRES QUE PARTICIPAN EN ESTA OPERACION., Y QUE ERA VERDAD QUE EL GOBIERNO NO GLORIA UN DESENLACE VIOLENTO.</data>
    </edge>
