    <edge source="Coronel" target="Periodistas" id="0">
      <data key="d5">ORDENA</data>
      <data key="d6">RECIBE_ORDEN</data>
      <data key="d7">False</data>
      <data key="d8">1701</data>
      <data key="d9">SOBRE LAS NUEVE Y DIEZ MINUTOS DE LA NOCHE, Y DESPUES DE QUE SE LEYERA ANTE LOS DIPUTADOS EL COMUNICADO DEL TENIENTE GENERAL MILANS DEL BOSCH, EL TENIENTE CORONEL DE LA GUARDIA CIVIL QUE ENCABEZABA A LAS FUERZAS OCUPANTES, ORDENO A LOS DIPUTADOS, PERIODISTAS E INVITADOS QUE MANTUVIERAN SILENCIO Y NO SE MOVIERAN DE SUNO A LAS FUERZA CASO DE QUE SE APAGARA LA LUZ Y AL PARECER, ORDENO A LAS FUERZAS QUE HICIERAN FUEGO SI SE DESOBEDECIA SU ORDEN.</data>
    </edge>
    <edge source="Coronel" target="Teniente General Milans Del Bosch" id="0">
      <data key="d5">ORDENA</data>
      <data key="d6">RECIBE_ORDEN</data>
      <data key="d7">False</data>
      <data key="d8">1701</data>
      <data key="d9">SOBRE LAS NUEVE Y DIEZ MINUTOS DE LA NOCHE, Y DESPUES DE QUE SE LEYERA ANTE LOS DIPUTADOS EL COMUNICADO DEL TENIENTE GENERAL MILANS DEL BOSCH, EL TENIENTE CORONEL DE LA GUARDIA CIVIL QUE ENCABEZABA A LAS FUERZAS OCUPANTES, ORDENO A LOS DIPUTADOS, PERIODISTAS E INVITADOS QUE MANTUVIERAN SILENCIO Y NO SE MOVIERAN DE SUNO A LAS FUERZA CASO DE QUE SE APAGARA LA LUZ Y AL PARECER, ORDENO A LAS FUERZAS QUE HICIERAN FUEGO SI SE DESOBEDECIA SU ORDEN.</data>
