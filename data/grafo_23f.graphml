    </edge>
    <edge source="Capitán Garcia Almenta" target="Comandante Cortina" id="1">
      <data key="d5">NIEGA</data>
      <data key="d6">NIEGA</data>
      <data key="d7">False</data>
      <data key="d8">1797</data>
      <data key="d9">J y F la niegan expresamente.</data>
    </edge>
    <edge source="Capitán Garcia Almenta" target="Comandante Cortina" id="2">
      <data key="d5">LLAMA</data>
      <data key="d6">LLAMA_A</data>
      <data key="d7">False</data>
      <data key="d8">1797</data>
      <data key="d9">En un momento dado, J llama a F desde la Central y le indica que "la DAC va a moverse".</data>
    </edge>
    <edge source="Capitán Garcia Almenta" target="Despacho" id="0">
      <data key="d5">CONOCE</data>
