    <edge source="La Coruña" target="Madrid" id="0">
      <data key="d5">AUTORIZA</data>
      <data key="d6">AUTORIZA</data>
      <data key="d7">False</data>
      <data key="d8">1810</data>
      <data key="d9">QUI TANA, defensor del General TORRES ROJAS y del Teniente de la - Guardia Civil NUÑEZ RUANO:  - Roja de Servicios del General TORRES ROJAS (parcial) - Teniente General FERNANDEZ POSE: El General TORRES R JAS fué autorizado a trasladarse a Madrid el 23-F, r gresando a la Coruña, el mismo día, poniéndose a sus órdenes.</data>
    </edge>
    <edge source="Capitán Gómez Iglesias" target="Presidente Del Tribunal" id="0">
      <data key="d5">CONOCE</data>
      <data key="d6">CONOCE</data>
      <data key="d7">False</data>
      <data key="d8">1847</data>
      <data key="d9">Negó conocer al Capitán Gómez Iglesias, y estimó que el CESID no coordinaba, aunque el Presidente del Tribunal dijo que no le interesaba su opinión.</data>
    </edge>
    <edge source="Capitán Gómez Iglesias" target="Presidente Del Tribunal" id="1">
      <data key="d5">NIEGA</data>
      <data key="d6">NIEGA</data>
