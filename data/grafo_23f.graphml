      <data key="d7">False</data>
      <data key="d8">1857</data>
      <data key="d9">Al reanudarse la sesión, el Coronel ESCANDELL (defensor del Teniente General MILANS DEL BOSCH y del Coronel IBAÑEZ) solicitó la lectura de la declaración del Teniente General GUTIERREZ MELLADO -y de las Hojas de Servicios de sus defendidos.</data>
    </edge>
    <edge source="Coronel Escandell" target="Defensor" id="1">
      <data key="d5">MENCIONA</data>
      <data key="d6">MENCIONA</data>
