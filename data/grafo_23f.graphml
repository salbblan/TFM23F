    <edge source="Parque" target="Radio" id="0">
      <data key="d5">NIEGA</data>
      <data key="d6">NIEGA</data>
      <data key="d7">False</data>
      <data key="d8">1700</data>
      <data key="d9">18,20 Noticias dadas por radio sobre asunto CORTES  19,00 Grupo Servicios Especiales./ Gente de Tráfico y Parque con uniforme y armamento tienen tomadas entradas al Parlamento y calles laterales./ Tienen órdenes de no hablar con nadie./ Tambien hay Policia Nacional./ Se niegan a hablar con personal del Grupo Servicios Especiales.</data>
    </edge>
