    <edge source="Este Procesado" target="Servicio" id="0">
      <data key="d5">INFORMA</data>
      <data key="d6">INFORMA_A</data>
      <data key="d7">False</data>
      <data key="d8">1843</data>
      <data key="d9">El fue quién informó a este procesado de la necesidad de oficiales para mandar a la fuerza, del lugar en que se iba a realizar el servicio y de que el mando lo ejercía el Teniente Coronel Tejero.</data>
    </edge>
    <edge source="Capitanías" target="Comandante Cortina" id="0">
      <data key="d5">MENCIONA</data>
      <data key="d6">MENCIONA</data>
      <data key="d7">False</data>
      <data key="d8">1843</data>
      <data key="d9">..El Comandante Bonel dijo en el Congreso que siete capitanías habían dado el beneplácito a los hechos y que solo quedaban la 1ª y 8ª.</data>
    </edge>
    <edge source="Capitanías" target="El Congreso" id="0">
      <data key="d5">MENCIONA</data>
